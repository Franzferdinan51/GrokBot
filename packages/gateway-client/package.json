{
  "name": "@grokbot/gateway-client",
  "version": "2026.7.2",
  "description": "Reference WebSocket client for the GrokBot Gateway protocol",
  "keywords": [
    "client",
    "gateway",
    "grokbot",
    "websocket"
  ],
  "homepage": "https://github.com/grokbot/grokbot#readme",
  "bugs": {
    "url": "https://github.com/grokbot/grokbot/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/grokbot/grokbot.git",
    "directory": "packages/gateway-client"
  },
  "files": [
    "dist",
    "npm-shrinkwrap.json",
    "LICENSE",
    "README.md",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./browser": {
      "types": "./dist/browser.d.mts",
      "import": "./dist/browser.mjs",
      "default": "./dist/browser.mjs"
    },
    "./readiness": {
      "types": "./dist/readiness.d.mts",
      "import": "./dist/readiness.mjs",
      "default": "./dist/readiness.mjs"
    },
    "./timeouts": {
      "types": "./dist/timeouts.d.mts",
      "import": "./dist/timeouts.mjs",
      "default": "./dist/timeouts.mjs"
    }
  },
  "scripts": {
    "build": "tsdown src/index.ts src/browser.ts src/readiness.ts src/timeouts.ts --no-config --platform node --format esm --dts --out-dir dist --clean"
  },
  "dependencies": {
    "@grokbot/gateway-protocol": "workspace:*",
    "ipaddr.js": "2.4.0",
    "ws": "8.21.0"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "grokbot": {
    "release": {
      "publishToNpm": true
    }
  }
}
