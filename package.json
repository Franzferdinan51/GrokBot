{
  "name": "grok-build-desktop-app",
  "version": "0.1.9",
  "private": true,
  "description": "Local-first AI coding desktop app powered by xAI Grok Build CLI",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @grok-build/desktop dev",
    "build": "pnpm --filter @grok-build/desktop build",
    "package": "pnpm --filter @grok-build/desktop package",
    "typecheck": "pnpm --filter @grok-build/desktop typecheck",
    "test:smoke": "pnpm --filter @grok-build/desktop test:smoke",
    "sync:grok-upstream": "bash scripts/sync-grok-fork.sh"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
