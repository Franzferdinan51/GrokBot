{
  "name": "@grokbot/brave-plugin",
  "version": "2026.7.2",
  "description": "GrokBot Brave Search provider plugin for web search.",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokbot/grokbot"
  },
  "type": "module",
  "devDependencies": {
    "@grokbot/plugin-sdk": "workspace:*"
  },
  "grokbot": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@grokbot/brave-plugin",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10",
      "allowInvalidConfigRecovery": true
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
