{
  "name": "@grokbot/vault",
  "version": "2026.7.2",
  "private": true,
  "description": "HashiCorp Vault SecretRef provider integration for GrokBot",
  "type": "module",
  "devDependencies": {
    "@grokbot/plugin-sdk": "workspace:*"
  },
  "grokbot": {
    "extensions": [
      "./index.ts"
    ],
    "build": {
      "staticAssets": [
        {
          "source": "./vault-secret-ref-resolver.js",
          "output": "vault-secret-ref-resolver.js"
        },
        {
          "source": "./vault-secret-id.js",
          "output": "vault-secret-id.js"
        }
      ]
    }
  }
}
