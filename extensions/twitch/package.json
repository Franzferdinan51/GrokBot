{
  "name": "@grokbot/twitch",
  "version": "2026.7.2",
  "description": "GrokBot Twitch channel plugin for chat and moderation workflows.",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokbot/grokbot"
  },
  "type": "module",
  "dependencies": {
    "@twurple/api-call": "8.1.4",
    "@twurple/auth": "8.1.4",
    "@twurple/chat": "8.1.4",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@grokbot/plugin-sdk": "workspace:*"
  },
  "grokbot": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "install": {
      "npmSpec": "@grokbot/twitch",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2"
    },
    "channel": {
      "id": "twitch",
      "configuredState": {
        "env": {
          "anyOf": [
            "OPENCLAW_TWITCH_ACCESS_TOKEN"
          ]
        }
      },
      "label": "Twitch",
      "selectionLabel": "Twitch (Chat)",
      "docsPath": "/channels/twitch",
      "blurb": "Twitch chat integration",
      "aliases": [
        "twitch-chat"
      ]
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
