{
  "name": "@grokbot/amazon-bedrock-mantle-provider",
  "version": "2026.7.2",
  "description": "GrokBot Amazon Bedrock Mantle provider plugin for OpenAI-compatible model routing.",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokbot/grokbot"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/sdk": "0.109.1",
    "@aws/bedrock-token-generator": "1.1.0"
  },
  "devDependencies": {
    "@grokbot/plugin-sdk": "workspace:*"
  },
  "grokbot": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@grokbot/amazon-bedrock-mantle-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
