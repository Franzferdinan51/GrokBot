{
  "name": "@grokbot/pixverse-provider",
  "version": "2026.7.2",
  "description": "GrokBot PixVerse video generation provider plugin.",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokbot/grokbot"
  },
  "type": "module",
  "devDependencies": {
    "@grokbot/plugin-sdk": "workspace:*",
    "grokbot": "workspace:*"
  },
  "peerDependencies": {
    "grokbot": ">=2026.7.2"
  },
  "peerDependenciesMeta": {
    "grokbot": {
      "optional": true
    }
  },
  "grokbot": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "clawhubSpec": "clawhub:@grokbot/pixverse-provider",
      "npmSpec": "@grokbot/pixverse-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.26"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
