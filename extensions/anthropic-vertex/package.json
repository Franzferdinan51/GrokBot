{
  "name": "@grokbot/anthropic-vertex-provider",
  "version": "2026.7.2",
  "description": "GrokBot Anthropic Vertex provider plugin for Claude models on Google Vertex AI.",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokbot/grokbot"
  },
  "type": "module",
  "dependencies": {
    "@anthropic-ai/vertex-sdk": "0.19.0",
    "google-auth-library": "10.9.0",
    "undici": "8.5.0"
  },
  "devDependencies": {
    "@grokbot/plugin-sdk": "workspace:*"
  },
  "grokbot": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@grokbot/anthropic-vertex-provider",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.12-beta.1"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2",
      "bundledDist": false
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
