{
  "name": "@grokbot/raft",
  "version": "2026.7.2",
  "description": "GrokBot Raft channel plugin for Raft CLI wake bridges.",
  "repository": {
    "type": "git",
    "url": "https://github.com/grokbot/grokbot"
  },
  "type": "module",
  "dependencies": {
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@grokbot/plugin-sdk": "workspace:*",
    "grokbot": "workspace:*"
  },
  "peerDependencies": {
    "grokbot": ">=2026.7.2"
  },
  "peerDependenciesMeta": {
    "grokbot": {
      "optional": true
    }
  },
  "grokbot": {
    "extensions": [
      "./index.ts"
    ],
    "setupEntry": "./setup-entry.ts",
    "install": {
      "npmSpec": "@grokbot/raft",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.6.8"
    },
    "compat": {
      "pluginApi": ">=2026.7.2"
    },
    "build": {
      "openclawVersion": "2026.7.2"
    },
    "channel": {
      "id": "raft",
      "configuredState": {
        "env": {
          "anyOf": [
            "RAFT_PROFILE"
          ]
        }
      },
      "label": "Raft",
      "selectionLabel": "Raft (CLI wake bridge)",
      "docsPath": "/channels/raft",
      "docsLabel": "raft",
      "blurb": "Raft CLI wake bridge for human and agent collaboration.",
      "order": 72
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}
